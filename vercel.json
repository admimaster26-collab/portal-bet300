{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/sw.js",        "dest": "/sw.js",        "headers": { "Cache-Control": "no-cache, no-store" } },
    { "src": "/manifest.json","dest": "/manifest.json","headers": { "Content-Type": "application/manifest+json" } },
    { "src": "/icons/(.*)",   "dest": "/icons/$1" },
    { "src": "/(.*)",         "dest": "/portal.html" }
  ]
}
